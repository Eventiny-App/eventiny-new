# Database URL — SQLite for local dev, PostgreSQL (Neon) for production
DATABASE_URL="file:./dev.db"

# JWT secret — CHANGE THIS in production
JWT_SECRET="dev-secret-change-in-production"

# SuperAdmin credentials — set once, used to seed the first admin account
SUPERADMIN_EMAIL="admin@eventiny.app"
SUPERADMIN_PASSWORD="changeme"
